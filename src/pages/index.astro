---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Drawer from '../components/Drawer.astro';

const SITE = 'https://sudjairakc.github.io/bkk-election-69-results-compare';
const TITLE = 'เลือกตั้ง ส.ก. กทม. เปรียบเทียบผล ปี 65 → 69 รายเขต';
const DESC =
  'เปรียบเทียบผลเลือกตั้ง ส.ก. กรุงเทพฯ ปี 2565 กับ 2569 ครบ 50 เขต — ' +
  '27 เขตเปลี่ยนกลุ่มพรรค, คนเดิมชนะซ้ำ 32 คน, ประชาชน(ก้าวไกล) 14→22 ที่นั่ง, ' +
  'เพื่อไทย 20→4, กลุ่มคนทำงาน 0→11 พร้อมกราฟ Sankey, ตาราง และผังเขตแบบ interactive';
const OG_IMG = `${SITE}/og.png`;

// Structured data — helps Google + AI engines (ChatGPT/Perplexity) understand & cite the dataset
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: TITLE,
  description: DESC,
  url: `${SITE}/`,
  inLanguage: 'th',
  keywords: [
    'เลือกตั้ง ส.ก.',
    'กทม. 2569',
    'ผลเลือกตั้งกรุงเทพ',
    'พรรคประชาชน',
    'เพื่อไทย',
    'เปรียบเทียบ 65 69',
  ],
  temporalCoverage: '2022/2026',
  spatialCoverage: { '@type': 'Place', name: 'กรุงเทพมหานคร, ประเทศไทย' },
  creator: { '@type': 'Person', name: 'sudjairakc' },
  isBasedOn: 'https://www.thaipbs.or.th/bkkelection69/result',
};
---
<!doctype html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{TITLE}</title>
  <meta name="description" content={DESC} />
  <link rel="canonical" href={`${SITE}/`} />

  <!-- Open Graph (Facebook / Line / etc.) -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="th_TH" />
  <meta property="og:site_name" content="เลือกตั้ง กทม. 65→69" />
  <meta property="og:title" content={TITLE} />
  <meta property="og:description" content={DESC} />
  <meta property="og:url" content={`${SITE}/`} />
  <meta property="og:image" content={OG_IMG} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={TITLE} />
  <meta name="twitter:description" content={DESC} />
  <meta name="twitter:image" content={OG_IMG} />

  <!-- Structured data for search + AI engines -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <!-- Cloudflare Web Analytics — privacy-first, no cookies.
       Dashboard: Analytics → Web analytics (hostname sudjairakc.github.io). -->
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon='{"token": "961c748b246f41b28df19476e04f5311"}'
  ></script>
</head>
<body>
  <Navbar />

  <div class="page-head">
    <h1 id="pageTitle">การเปลี่ยนพรรค/กลุ่ม ผู้นำเขต กทม. · ปี 65 → ปี 69</h1>
    <p class="sub" id="pageSub">ผู้สมัครอันดับ 1 แต่ละเขต · 50 เขต · แยกเป็น 2 มุมมอง</p>
    <div class="count-pill" id="countPill"></div>
  </div>

  <!-- Static summary for SEO + AI engines (text the charts render via JS won't expose) -->
  <p class="intro-summary">
    เปรียบเทียบผลการเลือกตั้งสมาชิกสภากรุงเทพมหานคร (ส.ก.) ปี 2565 กับ 2569 ครบทั้ง 50 เขต
    โดยเทียบเฉพาะผู้สมัครอันดับ 1 ของแต่ละเขต ผลสรุป: มี <b>27 เขต</b> ที่เปลี่ยนกลุ่มพรรค
    (พรรคเดิม 23 เขต), ผู้ชนะ <b>32 คน</b> เป็นคนเดิมที่ชนะซ้ำทั้งสองปี (หน้าใหม่ 18 คน).
    ด้านที่นั่งรายพรรค พรรคประชาชน (เดิมก้าวไกล) เพิ่มจาก 14 เป็น <b>22 ที่นั่ง</b>,
    เพื่อไทยลดจาก 20 เหลือ <b>4 ที่นั่ง</b>, และกลุ่มคนทำงานเป็นกลุ่มหน้าใหม่ได้ <b>11 ที่นั่ง</b>.
    ข้อมูลจาก Thai PBS นับคะแนนแล้วประมาณ 95% (อย่างไม่เป็นทางการ).
  </p>

  <div class="section" id="sec1">
    <div class="sec-head">
      <h2>① ที่นั่งเปลี่ยนมือ — มองที่ “เขต”</h2>
      <p class="note" id="noteSeat"></p>
    </div>
    <div class="chart-scroll"><svg id="chartSeat" width="980" height="680" viewBox="0 0 980 680"></svg></div>
  </div>

  <div class="section" id="sec2">
    <div class="sec-head">
      <h2>② คนเดิม — มองที่ “คน”</h2>
      <p class="note" id="notePerson"></p>
    </div>
    <div class="chart-scroll"><svg id="chartPerson" width="980" height="540" viewBox="0 0 980 540"></svg></div>
  </div>

  <div class="section" id="sec3">
    <div class="sec-head">
      <h2>③ จำนวนที่นั่งแต่ละพรรค/กลุ่ม — ปี 65 เทียบ 69</h2>
      <p class="note">นับรวมตาม “กลุ่มพรรคเดียวกัน” (ก้าวไกล=ประชาชน, เพื่อไทย=เพื่อไทย Life) · หน่วย = เขต (จาก 50)<br />แท่ง<b>จาง</b> = ปี 65 · แท่ง<b>เข้ม</b> = ปี 69</p>
    </div>
    <div class="chart-scroll"><svg id="chartBar" width="980" height="430" viewBox="0 0 980 430"></svg></div>
  </div>

  <div class="section" id="sec4">
    <div class="sec-head">
      <h2>④ ตารางผลรายเขต — ค้นหา / เรียงลำดับได้</h2>
      <p class="note">พิมพ์เพื่อค้นหาชื่อเขต ผู้สมัคร หรือพรรค · คลิกหัวคอลัมน์เพื่อเรียงลำดับ</p>
    </div>
    <div class="controls"><input id="tblSearch" class="search-box" type="text" placeholder="ค้นหา เขต / ผู้สมัคร / พรรค…" /></div>
    <div class="tbl-scroll"><table class="dtbl" id="dtbl"><thead></thead><tbody></tbody></table></div>
  </div>

  <div class="section" id="sec5">
    <div class="sec-head">
      <h2>⑤ ผังเขต ระบายสีตามพรรคผู้ชนะ</h2>
      <p class="note">แต่ละช่อง = 1 เขต (เรียงตามรหัสเขต) · <b>กรอบประ</b> = เขตที่เปลี่ยนกลุ่มพรรคจาก 65 → 69 · ชี้เพื่อดูรายละเอียด</p>
    </div>
    <div class="gridmaps">
      <div class="gridmap"><h3>ปี 65</h3><div class="tilegrid" id="grid65"></div></div>
      <div class="gridmap"><h3>ปี 69</h3><div class="tilegrid" id="grid69"></div></div>
    </div>
    <div class="legend" id="gridLegend"></div>
  </div>

  <div class="section" id="sec6">
    <div class="sec-head">
      <h2>⑥ คะแนนผู้ชนะรายเขต 65 → 69</h2>
      <p class="note">จุดซ้าย = คะแนนผู้ชนะปี 65 · จุดขวา = ปี 69 (สีจุด = พรรคของปีนั้น) · เส้น<b style="color:#2e9e5b">เขียว</b> = เพิ่มขึ้น, <b style="color:#d23b37">แดง</b> = ลดลง</p>
    </div>
    <div class="controls">
      <span style="font-size:11.5px;color:var(--sub)">เรียงตาม:</span>
      <button class="ctrl-btn active" data-sort="id">รหัสเขต</button>
      <button class="ctrl-btn" data-sort="v69">คะแนนปี 69</button>
      <button class="ctrl-btn" data-sort="delta">ส่วนต่าง</button>
    </div>
    <div class="chart-scroll"><svg id="chartDumbbell" width="980" height="1180" viewBox="0 0 980 1180"></svg></div>
  </div>

  <div class="section" id="sec7">
    <div class="sec-head">
      <h2>⑦ คนกรุงเทพเลือกที่ “คน” หรือ “พรรค”?</h2>
      <p class="note">เทียบผู้ชนะปี 65 กับ 69 รายเขต แยกเป็น 4 กลุ่ม · <b>คนเดิม</b> = ผู้ชนะคนเดียวกัน · <b>พรรคเดิม</b> = กลุ่มพรรคเดียวกัน (ก้าวไกล=ประชาชน, เพื่อไทย=เพื่อไทย Life) · ชี้ที่ช่อง/แถบเพื่อดูสูตรการคำนวณและรายเขต</p>
    </div>
    <div class="pp-wrap">
      <div class="ppgrid" id="ppMatrix"></div>
      <div class="pp-side" id="ppSide"></div>
    </div>
    <div class="pp-break" id="ppBreak"></div>
  </div>

  <footer class="page-foot">
    ข้อมูลจาก <a id="srcLink" target="_blank" rel="noopener"></a><br />
    <span id="footCounted"></span> · เปรียบเทียบเฉพาะผู้สมัครอันดับ 1 ของแต่ละเขต<br />
    <span id="footUpdated" style="opacity:.8"></span>
  </footer>

  <Drawer />

  <script>
    import '../main';
  </script>
</body>
</html>
