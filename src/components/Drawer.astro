---
// Floating tooltip, scrim, and the click-through detail drawer.
// Populated at runtime by src/charts/flow.ts and the tooltip module.
---
<div class="tt" id="tt"></div>
<div class="scrim" id="scrim"></div>
<aside class="panel" id="panel">
  <div class="panel-head">
    <button class="panel-close" id="panelClose">×</button>
    <div class="panel-kind" id="panelKind"></div>
    <div class="panel-flow" id="panelFlow"></div>
    <div class="panel-meta" id="panelMeta"></div>
  </div>
  <div class="panel-body" id="panelBody"></div>
</aside>
